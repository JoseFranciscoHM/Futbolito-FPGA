--B1L23 is VGA_SYNC:1|h_count~418 at LCCOMB_X42_Y19_N0
B1L23 = B1L91 & (B1_h_count[3] # B1L85 # !B1L95);


--B1L33 is VGA_SYNC:1|h_count~419 at LCCOMB_X42_Y19_N26
B1L33 = B1L71 & (B1_h_count[3] # B1L85 # !B1L95);



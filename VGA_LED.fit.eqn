--B1_horiz_sync_out is VGA_SYNC:1|horiz_sync_out at LCFF_X40_Y19_N1
B1_horiz_sync_out = DFFEAS(B1L83, GLOBAL(D1L2),  ,  ,  ,  ,  ,  ,  );



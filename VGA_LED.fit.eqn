--B1L09 is VGA_SYNC:1|v_count[9]~271 at LCCOMB_X41_Y19_N28
B1L09 = B1L88 $ B1_v_count[9];


--B1L44 is VGA_SYNC:1|LessThan~712 at LCCOMB_X40_Y19_N4
B1L44 = !B1_v_count[1] & !B1_v_count[0] # !B1_v_count[2] # !B1_v_count[3];


--B1L54 is VGA_SYNC:1|LessThan~713 at LCCOMB_X41_Y19_N0

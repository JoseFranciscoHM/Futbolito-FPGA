--B1L01 is VGA_SYNC:1|add~326 at LCCOMB_X15_Y35_N14
B1L01 = CARRY(B1_h_count[4] & !B1L8);


--B1L11 is VGA_SYNC:1|add~327 at LCCOMB_X15_Y35_N16

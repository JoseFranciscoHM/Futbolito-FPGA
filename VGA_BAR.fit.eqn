--B1L21 is VGA_SYNC:1|add~328 at LCCOMB_X15_Y35_N16
B1L21 = CARRY(!B1L01 # !B1_h_count[5]);


--B1L31 is VGA_SYNC:1|add~329 at LCCOMB_X15_Y35_N18

--Clock_50Mhz is Clock_50Mhz at PIN_N2
--operation mode is input

Clock_50Mhz = INPUT();


--VGA_Red is VGA_Red at PIN_E10
--operation mode is output

VGA_Red = OUTPUT(B1_red_out);


--VGA_Green is VGA_Green at PIN_D12
--operation mode is output

VGA_Green = OUTPUT(B1_green_out);


--VGA_HSync is VGA_HSync at PIN_A7
--operation mode is output

VGA_HSync = OUTPUT(B1_horiz_sync_out);


--VGA_VSync is VGA_VSync at PIN_D8
--operation mode is output

VGA_VSync = OUTPUT(B1_vert_sync_out);


--VGA_Blue is VGA_Blue at PIN_B12
--operation mode is output

VGA_Blue = OUTPUT(B1_blue_out);


--video_blank_out is video_blank_out at PIN_D6
--operation mode is output

video_blank_out = OUTPUT(B1_video_on);


--video_clock_out is video_clock_out at PIN_B8
--operation mode is output

video_clock_out = OUTPUT(GLOBAL(D1L2));





--D1L2 is VGA_SYNC:1|video_PLL:video_PLL_inst|altpll:altpll_component|_clk0~clkctrl at CLKCTRL_G2
D1L2 = cycloneii_clkctrl(.INCLK[0] = D1__clk0) WITH (clock_type = "Global Clock");


--B1L24 is VGA_SYNC:1|horiz_sync_out~feeder at LCCOMB_X14_Y35_N28
B1L24 = B1_horiz_sync;



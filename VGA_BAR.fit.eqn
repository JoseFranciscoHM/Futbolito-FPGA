--B1_horiz_sync is VGA_SYNC:1|horiz_sync at LCFF_X14_Y35_N1
B1_horiz_sync = DFFEAS(B1L16, GLOBAL(D1L2),  ,  ,  ,  ,  ,  ,  );


--B1_vert_sync is VGA_SYNC:1|vert_sync at LCFF_X17_Y35_N21

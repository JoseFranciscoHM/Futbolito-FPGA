--B1L73 is VGA_SYNC:1|h_count~419 at LCCOMB_X15_Y35_N4
B1L73 = B1L71 & (B1_h_count[3] # B1L96 # !B1L07);


--B1L17 is VGA_SYNC:1|reduce_nor~64 at LCCOMB_X16_Y35_N0

--B1_red_out is VGA_SYNC:1|red_out at LCFF_X17_Y35_N17
B1_red_out = DFFEAS(B1L76, GLOBAL(D1L2),  ,  ,  ,  ,  ,  ,  );


--B1_green_out is VGA_SYNC:1|green_out at LCFF_X17_Y35_N7
B1_green_out = DFFEAS(B1L42, GLOBAL(D1L2),  ,  ,  ,  ,  ,  ,  );


--B1_horiz_sync_out is VGA_SYNC:1|horiz_sync_out at LCFF_X14_Y35_N29
B1_horiz_sync_out = DFFEAS(B1L24, GLOBAL(D1L2),  ,  ,  ,  ,  ,  ,  );


--B1_vert_sync_out is VGA_SYNC:1|vert_sync_out at LCFF_X17_Y35_N1
B1_vert_sync_out = DFFEAS(UNCONNECTED_DATAIN, GLOBAL(D1L2),  ,  ,  , B1_vert_sync,  ,  , VCC);


--B1_blue_out is VGA_SYNC:1|blue_out at LCFF_X17_Y35_N25
B1_blue_out = DFFEAS(B1L22, GLOBAL(D1L2),  ,  ,  ,  ,  ,  ,  );


